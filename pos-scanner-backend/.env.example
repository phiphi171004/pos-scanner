PORT=5000
MONGODB_URI=your_mongodb_connection_string

# R2 Configuration
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_access_key
R2_SECRET_ACCESS_KEY=your_secret_key
R2_BUCKET_NAME=your_bucket_name
R2_PUBLIC_URL=your_r2_public_custom_domain_or_pub_url

# JWT Configuration
JWT_SECRET=any_long_random_string_here
JWT_EXPIRE=15m
JWT_REFRESH_SECRET=another_long_random_string_DIFFERENT_from_JWT_SECRET
JWT_REFRESH_EXPIRE=30d

# Email Configuration (Brevo SMTP qua Nodemailer)
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
BREVO_SMTP_USER=your_brevo_smtp_login@smtp-brevo.com
BREVO_SMTP_KEY=your_brevo_smtp_key
FROM_EMAIL=noreply@shopsheap.online
FROM_NAME=POS Scanner
